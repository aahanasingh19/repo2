# ========================================
# One_Cart — Environment Configuration
# ========================================
# Copy relevant variables to backend/.env and frontend/.env

# --- Backend (backend/.env) ---
PORT=8000
MONGODB_URL=mongodb+srv://your_connection_string
JWT_SECRET=your_jwt_secret_here
ADMIN_EMAIL=admin@onecart.com
ADMIN_PASSWORD=your_admin_password
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_APIKEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_KEY_ID=your_razorpay_key_id
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# --- Frontend (frontend/.env) ---
VITE_FIREBASE_APIKEY=your_firebase_api_key
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
